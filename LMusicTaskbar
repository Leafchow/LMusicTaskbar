- AutoTheme: true
  $name: Auto Theme
  $description: Automatically match the light/dark Windows theme
- TextColor: "FFFFFF"
  $name: Text Color (hex)
  $description: Manual text color as hex RGB e.g. FFFFFF. Used only when Auto Theme is off.
- BgOpacity: 0
  $name: Background Opacity
  $description: Background tint opacity 0 to 255. Used only when Auto Theme is off.
- HideFullscreen: false
  $name: Hide in Fullscreen
  $description: Automatically hide the panel when a fullscreen app is running
- IdleTimeout: 0
  $name: Idle Hide Timeout (seconds)
  $description: Hide after playback has been paused for this many seconds. Set to 0 to disable.
*/
