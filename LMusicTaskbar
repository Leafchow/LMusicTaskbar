float GetSystemVolume() {
    IMMDeviceEnumerator* pEnum = nullptr;
    IMMDevice* pDevice = nullptr;
    IAudioEndpointVolume* pVol = nullptr;
    float vol = 0.5f;
    if (SUCCEEDED(CoCreateInstance(__uuidof(MMDeviceEnumerator), nullptr, CLSCTX_ALL, IID_PPV_ARGS(&pEnum)))) {
        if (SUCCEEDED(pEnum->GetDefaultAudioEndpoint(eRender, eConsole, &pDevice))) {
            if (SUCCEEDED(pDevice->Activate(__uuidof(IAudioEndpointVolume), CLSCTX_ALL, nullptr, (void**)&pVol))) {
                pVol->GetMasterVolumeLevelScalar(&vol);
                pVol->Release();
            }
            pDevice->Release();
        }
        pEnum->Release();
    }
    return vol;
}

void SetSystemVolume(float vol) {
    vol = max(0.0f, min(1.0f, vol));
    IMMDeviceEnumerator* pEnum = nullptr;
    IMMDevice* pDevice = nullptr;
    IAudioEndpointVolume* pVol = nullptr;
    if (SUCCEEDED(CoCreateInstance(__uuidof(MMDeviceEnumerator), nullptr, CLSCTX_ALL, IID_PPV_ARGS(&pEnum)))) {
        if (SUCCEEDED(pEnum->GetDefaultAudioEndpoint(eRender, eConsole, &pDevice))) {
            if (SUCCEEDED(pDevice->Activate(__uuidof(IAudioEndpointVolume), CLSCTX_ALL, nullptr, (void**)&pVol))) {
                pVol->SetMasterVolumeLevelScalar(vol, nullptr);
                pVol->Release();
            }
            pDevice->Release();
        }
        pEnum->Release();
    }
}

struct SliderGeometry { float startX, endX, y, width; };

SliderGeometry GetSliderGeometry(int height) {
    double scale = g_Settings.buttonScale;
    int artSize = height - 12;
    int scx = 6 + artSize + (int)(12 * scale);
    float cr = 12.0f * (float)scale;
    float pX = (float)scx;
    float nX = pX + 28.0f * (float)scale * 2.0f;
    SliderGeometry sg;
    sg.startX = pX - cr;
    sg.endX   = nX + cr;
    sg.width  = sg.endX - sg.startX;
    sg.y      = (float)(height - 10);
    return sg;
}

SliderGeometry GetProgressSliderGeometry(int width, int height) {
    double scale = g_Settings.buttonScale;
    SliderGeometry vs = GetSliderGeometry(height);
    float gap = 8.0f;
    SliderGeometry sg;
    sg.startX = vs.endX + gap;
    sg.endX = (float)(width - 10);
    sg.width = max(0.0f, sg.endX - sg.startX);
    sg.y = vs.y;
    return sg;
}

void LoadSettings() {
    g_Settings.width          = Wh_GetIntSetting(L"PanelWidth");
    g_Settings.height         = Wh_GetIntSetting(L"PanelHeight");
    g_Settings.fontSize       = Wh_GetIntSetting(L"FontSize");
    g_Settings.offsetX        = Wh_GetIntSetting(L"OffsetX");
    g_Settings.offsetY        = Wh_GetIntSetting(L"OffsetY");
    g_Settings.autoTheme      = Wh_GetIntSetting(L"AutoTheme") != 0;
    g_Settings.hideFullscreen = Wh_GetIntSetting(L"HideFullscreen") != 0;
    g_Settings.idleTimeout    = Wh_GetIntSetting(L"IdleTimeout");

    PCWSTR scaleStr = Wh_GetStringSetting(L"ButtonScale");
    g_Settings.buttonScale = scaleStr ? _wtof(scaleStr) : 1.0;
    if (scaleStr) Wh_FreeStringSetting(scaleStr);
    g_Settings.buttonScale = max(0.5, min(4.0, g_Settings.buttonScale));

    PCWSTR textHex = Wh_GetStringSetting(L"TextColor");
    DWORD textRGB = textHex && wcslen(textHex) > 0 ? wcstoul(textHex, nullptr, 16) : 0xFFFFFF;
    if (textHex) Wh_FreeStringSetting(textHex);
    g_Settings.manualTextColor = 0xFF000000 | textRGB;

    g_Settings.bgOpacity = max(0, min(255, Wh_GetIntSetting(L"BgOpacity")));
    if (g_Settings.width  < 100) g_Settings.width  = 300;
    if (g_Settings.height < 24)  g_Settings.height = 48;
}

GlobalSystemMediaTransportControlsSessionManager g_SessionManager = nullptr;

Bitmap* StreamToBitmap(IRandomAccessStreamWithContentType const& stream) {
    if (!stream) return nullptr;
    IStream* ns = nullptr;
    if (SUCCEEDED(CreateStreamOverRandomAccessStream(
            reinterpret_cast<IUnknown*>(winrt::get_abi(stream)), IID_PPV_ARGS(&ns)))) {
        Bitmap* bmp = Bitmap::FromStream(ns);
        ns->Release();
        if (bmp && bmp->GetLastStatus() == Ok) return bmp;
        delete bmp;
    }
    return nullptr;
}

wstring FormatTime(double seconds) {
    if (seconds < 0.0) seconds = 0.0;
    int total = (int)(seconds + 0.5);
    int mins = total / 60;
    int secs = total % 60;
    wchar_t buf[16];
    swprintf_s(buf, L"%d:%02d", mins, secs);
    return buf;
}

void UpdateMediaInfo() {
    try {
        if (!g_SessionManager)
            g_SessionManager = GlobalSystemMediaTransportControlsSessionManager::RequestAsync().get();
        if (!g_SessionManager) return;

        GlobalSystemMediaTransportControlsSession session = nullptr;
        for (auto const& s : g_SessionManager.GetSessions()) {
            auto pb = s.GetPlaybackInfo();
            if (pb && pb.PlaybackStatus() == GlobalSystemMediaTransportControlsSessionPlaybackStatus::Playing) {
                session = s; break;
            }
        }
        if (!session) session = g_SessionManager.GetCurrentSession();

        if (session) {
            auto props = session.TryGetMediaPropertiesAsync().get();
            auto info  = session.GetPlaybackInfo();
            lock_guard<mutex> guard(g_MediaState.lock);
            wstring newTitle = props.Title().c_str();
            if (newTitle != g_MediaState.title || !g_MediaState.albumArt) {
                delete g_MediaState.albumArt;
                g_MediaState.albumArt = nullptr;
                auto thumbRef = props.Thumbnail();
                if (thumbRef)
                    g_MediaState.albumArt = StreamToBitmap(thumbRef.OpenReadAsync().get());
            }
            g_MediaState.title     = newTitle;
            g_MediaState.artist    = props.Artist().c_str();
            g_MediaState.isPlaying = info.PlaybackStatus() == GlobalSystemMediaTransportControlsSessionPlaybackStatus::Playing;
            try {
                auto timeline = session.GetTimelineProperties();
                g_MediaState.position = (double)timeline.Position().count() / 10000000.0;
                g_MediaState.duration = max(1.0, (double)timeline.EndTime().count() / 10000000.0);
            } catch (...) {
                g_MediaState.position = 0.0;
                g_MediaState.duration = 1.0;
            }
            g_MediaState.hasMedia  = true;
        } else {
            lock_guard<mutex> guard(g_MediaState.lock);
            g_MediaState.hasMedia = false;
            g_MediaState.title    = L"No Media";
            g_MediaState.artist   = L"";
            delete g_MediaState.albumArt;
            g_MediaState.albumArt = nullptr;
        }
    } catch (...) {
        lock_guard<mutex> guard(g_MediaState.lock);
        g_MediaState.hasMedia = false;
    }
}

void SendMediaCommand(int cmd) {
    try {
        if (!g_SessionManager) return;
        auto session = g_SessionManager.GetCurrentSession();
        if (!session) return;
        if      (cmd == 1) session.TrySkipPreviousAsync();
        else if (cmd == 2) session.TryTogglePlayPauseAsync();
        else if (cmd == 3) session.TrySkipNextAsync();
    } catch (...) {}
}

bool IsSystemLightMode() {
    DWORD value = 0, size = sizeof(value);
    return RegGetValueW(HKEY_CURRENT_USER,
        L"Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize",
        L"SystemUsesLightTheme", RRF_RT_DWORD, nullptr, &value, &size) == ERROR_SUCCESS && value != 0;
}

DWORD GetCurrentTextColor() {
    if (g_Settings.autoTheme) return IsSystemLightMode() ? 0xFF000000 : 0xFFFFFFFF;
    return g_Settings.manualTextColor;
}

void UpdateAppearance(HWND hwnd) {
    DWM_WINDOW_CORNER_PREFERENCE pref = DWMWCP_ROUND;
    DwmSetWindowAttribute(hwnd, DWMWA_WINDOW_CORNER_PREFERENCE, &pref, sizeof(pref));
    HMODULE hUser = GetModuleHandle(L"user32.dll");
    if (!hUser) return;
    auto SetComp = (pSetWindowCompositionAttribute)GetProcAddress(hUser, "SetWindowCompositionAttribute");
    if (!SetComp) return;
    DWORD tint = g_Settings.autoTheme
        ? (IsSystemLightMode() ? 0x40FFFFFF : 0x40000000)
        : ((g_Settings.bgOpacity << 24) | 0xFFFFFF);
    ACCENT_POLICY policy = { ACCENT_ENABLE_ACRYLICBLURBEHIND, 0, tint, 0 };
    WINDOWCOMPOSITIONATTRIBDATA data = { WCA_ACCENT_POLICY, &policy, sizeof(policy) };
    SetComp(hwnd, &data);
}

void AddRoundedRect(GraphicsPath& path, int x, int y, int w, int h, int r) {
    int d = r * 2;
    path.AddArc(x,         y,         d, d, 180, 90);
    path.AddArc(x + w - d, y,         d, d, 270, 90);
    path.AddArc(x + w - d, y + h - d, d, d,   0, 90);
    path.AddArc(x,         y + h - d, d, d,  90, 90);
    path.CloseFigure();
}

void DrawMediaPanel(HDC hdc, int width, int height) {
    Graphics g(hdc);
    g.SetSmoothingMode(SmoothingModeAntiAlias);
    g.SetTextRenderingHint(TextRenderingHintAntiAlias);
    g.Clear(Color(0, 0, 0, 0));

    Color mc{ GetCurrentTextColor() };

    MediaState state;
    {
        lock_guard<mutex> guard(g_MediaState.lock);
        state.title     = g_MediaState.title;
        state.artist    = g_MediaState.artist;
        state.albumArt  = g_MediaState.albumArt ? g_MediaState.albumArt->Clone() : nullptr;
        state.hasMedia  = g_MediaState.hasMedia;
        state.isPlaying = g_MediaState.isPlaying;
        state.position  = g_MediaState.position;
        state.duration  = max(1.0, g_MediaState.duration);
    }

    // Album art
    int artSize = height - 12;
    GraphicsPath artPath;
    AddRoundedRect(artPath, 6, 6, artSize, artSize, 8);
    if (state.albumArt) {
        g.SetClip(&artPath);
        g.DrawImage(state.albumArt, 6, 6, artSize, artSize);
        g.ResetClip();
        delete state.albumArt;
    } else {
        SolidBrush ph{ Color(40, 128, 128, 128) };
        g.FillPath(&ph, &artPath);
    }

    // Media controls
    double scale = g_Settings.buttonScale;
    int scx = 6 + artSize + (int)(12 * scale);
    int controlY = height / 2 - 8;

    SolidBrush iconBrush{ mc };
    SolidBrush hoverBrush{ Color(255, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
    SolidBrush activeBg{ Color(40,  mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };

    float cr  = 12.0f * (float)scale;
    float iw  =  8.0f * (float)scale;
    float ih  = 12.0f * (float)scale;
    float gap = 28.0f * (float)scale;
    float pX  = (float)scx, plX = pX + gap, nX = plX + gap;

    auto* ib = &iconBrush;
    auto* hb = &hoverBrush;

    if (g_HoverState == 1) g.FillEllipse(&activeBg, pX-cr, (float)controlY-cr, cr*2, cr*2);
    PointF prevPts[3] = { {pX+iw,(float)controlY-ih/2}, {pX+iw,(float)controlY+ih/2}, {pX,(float)controlY} };
    g.FillPolygon(g_HoverState==1?hb:ib, prevPts, 3);
    g.FillRectangle(g_HoverState==1?hb:ib, pX, (float)controlY-ih/2, 2.0f*(float)scale, ih);

    if (g_HoverState == 2) g.FillEllipse(&activeBg, plX-cr, (float)controlY-cr, cr*2, cr*2);
    if (state.isPlaying) {
        float bw = 3.0f*(float)scale, bh = 14.0f*(float)scale;
        g.FillRectangle(g_HoverState==2?hb:ib, plX-(bw+1), (float)controlY-bh/2, bw, bh);
        g.FillRectangle(g_HoverState==2?hb:ib, plX+1,       (float)controlY-bh/2, bw, bh);
    } else {
        float pw = 10.0f*(float)scale, ph2 = 16.0f*(float)scale;
        PointF playPts[3] = { {plX-pw/2,(float)controlY-ph2/2}, {plX-pw/2,(float)controlY+ph2/2}, {plX+pw/2,(float)controlY} };
        g.FillPolygon(g_HoverState==2?hb:ib, playPts, 3);
    }

    if (g_HoverState == 3) g.FillEllipse(&activeBg, nX-cr, (float)controlY-cr, cr*2, cr*2);
    PointF nextPts[3] = { {nX-iw,(float)controlY-ih/2}, {nX-iw,(float)controlY+ih/2}, {nX,(float)controlY} };
    g.FillPolygon(g_HoverState==3?hb:ib, nextPts, 3);
    g.FillRectangle(g_HoverState==3?hb:ib, nX, (float)controlY-ih/2, 2.0f*(float)scale, ih);

    // Scrolling text
    int textX    = (int)(nX + 20 * scale);
    int textMaxW = width - textX - 10;
    wstring fullText = state.title;
    if (!state.artist.empty()) fullText += L" \u2022 " + state.artist;

    FontFamily ff(FONT_NAME, nullptr);
    Font font(&ff, (REAL)g_Settings.fontSize, FontStyleBold, UnitPixel);
    SolidBrush textBrush{ mc };

    RectF boundRect;
    g.MeasureString(fullText.c_str(), -1, &font, RectF(0,0,2000,100), &boundRect);
    g_TextWidth = (int)boundRect.Width;

    Region textClip(Rect(textX, 0, textMaxW, height));
    g.SetClip(&textClip);
    float textY = 6.0f;

    if (g_TextWidth > textMaxW) {
        g_IsScrolling = true;
        float drawX = (float)(textX - g_ScrollOffset);
        g.DrawString(fullText.c_str(), -1, &font, PointF(drawX, textY), &textBrush);
        if (drawX + g_TextWidth < width)
            g.DrawString(fullText.c_str(), -1, &font, PointF(drawX + g_TextWidth + 40, textY), &textBrush);
    } else {
        g_IsScrolling = false;
        g_ScrollOffset = 0;
        g.DrawString(fullText.c_str(), -1, &font, PointF((float)textX, textY), &textBrush);
    }
    g.ResetClip();

    // Timer and volume percentage above the sliders
    double displayPosition = g_IsDraggingProgressSlider ? (g_CurrentProgress * state.duration) : state.position;
    wstring timerText = FormatTime(displayPosition) + L" / " + FormatTime(state.duration);
    wchar_t volBuf[16];
    swprintf_s(volBuf, L"%d%%", (int)(g_CurrentVolume * 100.0f + 0.5f));
    wstring volumeText = volBuf;
    Font timerFont(&ff, (REAL)max(8, g_Settings.fontSize - 2), FontStyleBold, UnitPixel);
    RectF timerBounds;
    g.MeasureString(timerText.c_str(), -1, &timerFont, RectF(0,0,200,50), &timerBounds);
    RectF volBounds;
    g.MeasureString(volumeText.c_str(), -1, &timerFont, RectF(0,0,200,50), &volBounds);
    SliderGeometry pg = GetProgressSliderGeometry(width, height);
    SliderGeometry sg = GetSliderGeometry(height);
    float timerY = textY + boundRect.Height + 3.5f;
    g.DrawString(timerText.c_str(), -1, &timerFont, PointF(pg.startX, timerY), &textBrush);
    float volX = max(sg.startX, sg.startX + sg.width - volBounds.Width);
    g.DrawString(volumeText.c_str(), -1, &timerFont, PointF(volX, timerY), &textBrush);

    // Progress slider on the same line as the volume slider
    float progressFill = (float)(g_CurrentProgress * pg.width);
    {
        SolidBrush trackBg{ Color(40, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
        GraphicsPath tp;
        AddRoundedRect(tp, (int)pg.startX, (int)(pg.y - 1.5f), (int)pg.width, 3, 1);
        g.FillPath(&trackBg, &tp);
    }
    if (progressFill > 1.0f) {
        SolidBrush fill{ Color(200, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
        GraphicsPath fp;
        AddRoundedRect(fp, (int)pg.startX, (int)(pg.y - 1.5f), (int)progressFill, 3, 1);
        g.FillPath(&fill, &fp);
    }

    // Volume slider with icon on the right
    sg = GetSliderGeometry(height);
    float trackH = 3.0f;
    float thumbR = 5.0f * (float)scale;
    float thumbX = sg.startX + g_CurrentVolume * sg.width;
    bool hovVolume = (g_HoverState == 4 || g_IsDraggingVolumeSlider);
    {
        SolidBrush trackBg{ Color(55, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
        GraphicsPath tp;
        AddRoundedRect(tp, (int)sg.startX, (int)(sg.y - trackH/2), (int)sg.width, (int)trackH, 1);
        g.FillPath(&trackBg, &tp);
    }
    {
        float fw = g_CurrentVolume * sg.width;
        if (fw > 1.0f) {
            SolidBrush fill{ Color(200, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
            GraphicsPath fp;
            AddRoundedRect(fp, (int)sg.startX, (int)(sg.y - trackH/2), (int)fw, (int)trackH, 1);
            g.FillPath(&fill, &fp);
        }
    }
    {
        float tr = hovVolume ? thumbR * 1.25f : thumbR;
        SolidBrush thumb{ Color(hovVolume ? 255 : 180, mc.GetRed(), mc.GetGreen(), mc.GetBlue()) };
        g.FillEllipse(&thumb, thumbX - tr, sg.y - tr, tr * 2.0f, tr * 2.0f);
    }
}

bool IsTaskbarWindow(HWND hwnd) {
    WCHAR cls[64];
    if (!hwnd) return false;
    GetClassNameW(hwnd, cls, ARRAYSIZE(cls));
    return wcscmp(cls, L"Shell_TrayWnd") == 0;
}

void CALLBACK TaskbarEventProc(HWINEVENTHOOK, DWORD, HWND hwnd, LONG, LONG, DWORD, DWORD) {
    if (!IsTaskbarWindow(hwnd) || !g_hMediaWindow) return;
    PostMessage(g_hMediaWindow, WM_APP + 10, 0, 0);
}

void RegisterTaskbarHook(HWND hwnd) {
    HWND hTaskbar = FindWindow(L"Shell_TrayWnd", nullptr);
    if (hTaskbar) {
        DWORD pid = 0, tid = GetWindowThreadProcessId(hTaskbar, &pid);
        if (tid)
            g_TaskbarHook = SetWinEventHook(EVENT_OBJECT_LOCATIONCHANGE, EVENT_OBJECT_LOCATIONCHANGE,
                nullptr, TaskbarEventProc, pid, tid, WINEVENT_OUTOFCONTEXT | WINEVENT_SKIPOWNPROCESS);
    }
    PostMessage(hwnd, WM_APP + 10, 0, 0);
}

#define IDT_POLL_MEDIA 1001
#define IDT_ANIMATION  1002
#define APP_WM_CLOSE   WM_APP

LRESULT CALLBACK MediaWndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
        case WM_CREATE:
            UpdateAppearance(hwnd);
            SetTimer(hwnd, IDT_POLL_MEDIA, 1000, NULL);
            RegisterTaskbarHook(hwnd);
            g_CurrentVolume = GetSystemVolume();
            return 0;

        case WM_ERASEBKGND: return 1;
        case WM_CLOSE:      return 0;

        case APP_WM_CLOSE:
            DestroyWindow(hwnd);
            return 0;

        case WM_DESTROY:
            if (g_TaskbarHook) { UnhookWinEvent(g_TaskbarHook); g_TaskbarHook = nullptr; }
            g_SessionManager = nullptr;
            PostQuitMessage(0);
            return 0;

        case WM_SETTINGCHANGE:
            UpdateAppearance(hwnd);
            InvalidateRect(hwnd, NULL, TRUE);
            return 0;

        case WM_TIMER:
            if (wParam == IDT_POLL_MEDIA) {
                UpdateMediaInfo();
                if (!g_IsDraggingVolumeSlider) g_CurrentVolume = GetSystemVolume();
                if (!g_IsDraggingProgressSlider) {
                    lock_guard<mutex> guard(g_MediaState.lock);
                    if (g_MediaState.duration > 0.0) {
                        g_CurrentProgress = max(0.0, min(1.0, g_MediaState.position / g_MediaState.duration));
                    }
                }

                bool shouldHide = false;
                if (g_Settings.hideFullscreen) {
                    QUERY_USER_NOTIFICATION_STATE qs;
                    if (SUCCEEDED(SHQueryUserNotificationState(&qs)))
                        if (qs == QUNS_BUSY || qs == QUNS_RUNNING_D3D_FULL_SCREEN || qs == QUNS_PRESENTATION_MODE)
                            shouldHide = true;
                }

                bool isPlaying = false;
                { lock_guard<mutex> guard(g_MediaState.lock); isPlaying = g_MediaState.isPlaying; }

                if (g_Settings.idleTimeout > 0) {
                    if (isPlaying) { g_IdleSecondsCounter = 0; g_IsHiddenByIdle = false; }
                    else if (++g_IdleSecondsCounter >= g_Settings.idleTimeout) g_IsHiddenByIdle = true;
                } else g_IsHiddenByIdle = false;

                if (g_IsHiddenByIdle) shouldHide = true;

                if (shouldHide && IsWindowVisible(hwnd))
                    ShowWindow(hwnd, SW_HIDE);
                else if (!shouldHide && !IsWindowVisible(hwnd)) {
                    HWND ht = FindWindow(L"Shell_TrayWnd", nullptr);
                    if (ht && IsWindowVisible(ht)) ShowWindow(hwnd, SW_SHOWNOACTIVATE);
                }
                InvalidateRect(hwnd, NULL, FALSE);
            } else if (wParam == IDT_ANIMATION) {
                if (g_IsScrolling) {
                    if (g_ScrollWait > 0) g_ScrollWait--;
                    else {
                        if (++g_ScrollOffset > g_TextWidth + 40) { g_ScrollOffset = 0; g_ScrollWait = 60; }
                        InvalidateRect(hwnd, NULL, FALSE);
                    }
                } else KillTimer(hwnd, IDT_ANIMATION);
            }
            return 0;

        case WM_APP + 10: {
            HWND ht = FindWindow(TEXT("Shell_TrayWnd"), nullptr);
            if (!ht) break;
            if (!IsWindowVisible(ht)) { if (IsWindowVisible(hwnd)) ShowWindow(hwnd, SW_HIDE); return 0; }

            if (!g_IsHiddenByIdle && !IsWindowVisible(hwnd)) {
                bool gameHide = false;
                if (g_Settings.hideFullscreen) {
                    QUERY_USER_NOTIFICATION_STATE qs;
                    if (SUCCEEDED(SHQueryUserNotificationState(&qs)))
                        if (qs == QUNS_BUSY || qs == QUNS_RUNNING_D3D_FULL_SCREEN || qs == QUNS_PRESENTATION_MODE)
                            gameHide = true;
                }
                if (!gameHide) ShowWindow(hwnd, SW_SHOWNOACTIVATE);
            }

            RECT rc; GetWindowRect(ht, &rc);
            int x = rc.left + g_Settings.offsetX;
            int y = rc.top + (rc.bottom - rc.top) / 2 - g_Settings.height / 2 + g_Settings.offsetY;
            RECT myRc; GetWindowRect(hwnd, &myRc);
            if (myRc.left != x || myRc.top != y ||
                myRc.right - myRc.left != g_Settings.width ||
                myRc.bottom - myRc.top != g_Settings.height)
                SetWindowPos(hwnd, HWND_TOPMOST, x, y, g_Settings.width, g_Settings.height, SWP_NOACTIVATE);
            return 0;
        }

        case WM_LBUTTONDOWN: {
            int mx = (int)(short)LOWORD(lParam), my = (int)(short)HIWORD(lParam);
            SliderGeometry vsg = GetSliderGeometry(g_Settings.height);
            float progressY = (float)g_Settings.height - 18.0f;
            if (my >= vsg.y-8 && my <= vsg.y+8 && mx >= vsg.startX && mx <= vsg.endX) {
                g_IsDraggingVolumeSlider = true;
                SetCapture(hwnd);
                float vol = max(0.0f, min(1.0f, (mx - vsg.startX) / vsg.width));
                g_CurrentVolume = vol;
                SetSystemVolume(vol);
                InvalidateRect(hwnd, NULL, FALSE);
            } else if (my >= progressY - 8 && my <= progressY + 8) {
                SliderGeometry pg = GetProgressSliderGeometry(g_Settings.width, g_Settings.height);
                if (mx >= pg.startX && mx <= pg.endX) {
                    g_IsDraggingProgressSlider = true;
                    SetCapture(hwnd);
                    double progress = (double)(mx - pg.startX) / (double)pg.width;
                    g_CurrentProgress = max(0.0, min(1.0, progress));
                    InvalidateRect(hwnd, NULL, FALSE);
                }
            }
            return 0;
        }

        case WM_MOUSEMOVE: {
            int mx = (int)(short)LOWORD(lParam), my = (int)(short)HIWORD(lParam);
            if (g_IsDraggingVolumeSlider) {
                SliderGeometry sg = GetSliderGeometry(g_Settings.height);
                float vol = max(0.0f, min(1.0f, (mx - sg.startX) / sg.width));
                g_CurrentVolume = vol;
                SetSystemVolume(vol);
                InvalidateRect(hwnd, NULL, FALSE);
                return 0;
            }
            if (g_IsDraggingProgressSlider) {
                SliderGeometry pg = GetProgressSliderGeometry(g_Settings.width, g_Settings.height);
                double progress = (double)(mx - pg.startX) / (double)pg.width;
                g_CurrentProgress = max(0.0, min(1.0, progress));
                InvalidateRect(hwnd, NULL, FALSE);
                return 0;
            }

            double scale = g_Settings.buttonScale;
            int artSize = g_Settings.height - 12;
            int startCX = 6 + artSize + (int)(12 * scale);
            float gap = 28.0f*(float)scale, cr = 12.0f*(float)scale;
            float pX = (float)startCX, plX = pX+gap, nX = plX+gap;
            SliderGeometry sg = GetSliderGeometry(g_Settings.height);
            SliderGeometry pg = GetProgressSliderGeometry(g_Settings.width, g_Settings.height);
            float progressY = (float)g_Settings.height - 18.0f;

            int newState = 0;
            if (my >= sg.y-8 && my <= sg.y+8 && mx >= sg.startX && mx <= sg.endX)
                newState = 4;
            else if (my >= progressY-8 && my <= progressY+8 && mx >= pg.startX && mx <= pg.endX)
                newState = 5;
            else if (my > 4 && my < g_Settings.height - 16) {
                if      (mx >= pX -cr && mx <= pX +cr) newState = 1;
                else if (mx >= plX-cr && mx <= plX+cr) newState = 2;
                else if (mx >= nX -cr && mx <= nX +cr) newState = 3;
            }

            if (newState != g_HoverState) { g_HoverState = newState; InvalidateRect(hwnd, NULL, FALSE); }
            TRACKMOUSEEVENT tme = { sizeof(tme), TME_LEAVE, hwnd, 0 };
            TrackMouseEvent(&tme);
            return 0;
        }

        case WM_MOUSELEAVE:
            g_HoverState = 0;
            InvalidateRect(hwnd, NULL, FALSE);
            break;

        case WM_LBUTTONUP:
            if (g_IsDraggingVolumeSlider) {
                g_IsDraggingVolumeSlider = false;
                ReleaseCapture();
            } else if (g_IsDraggingProgressSlider) {
                g_IsDraggingProgressSlider = false;
                ReleaseCapture();
                try {
                    if (g_SessionManager) {
                        auto session = g_SessionManager.GetCurrentSession();
                        if (session) {
                            lock_guard<mutex> guard(g_MediaState.lock);
                            double duration = max(1.0, g_MediaState.duration);
                            int64_t ticks = (int64_t)(g_CurrentProgress * duration * 10000000.0);
                            session.TryChangePlaybackPositionAsync(ticks).get();
                        }
                    }
                } catch (...) {}
            } else if (g_HoverState > 0 && g_HoverState < 4) {
                SendMediaCommand(g_HoverState);
            }
            return 0;

        case WM_MOUSEWHEEL: {
            short zDelta = GET_WHEEL_DELTA_WPARAM(wParam);
            float newVol = max(0.0f, min(1.0f, g_CurrentVolume + (zDelta > 0 ? 0.05f : -0.05f)));
            g_CurrentVolume = newVol;
            SetSystemVolume(newVol);
            InvalidateRect(hwnd, NULL, FALSE);
            return 0;
        }

        case WM_PAINT: {
            PAINTSTRUCT ps;
            HDC hdc = BeginPaint(hwnd, &ps);
            RECT rc; GetClientRect(hwnd, &rc);
            HDC memDC = CreateCompatibleDC(hdc);
            HBITMAP memBmp = CreateCompatibleBitmap(hdc, rc.right, rc.bottom);
            HBITMAP oldBmp = (HBITMAP)SelectObject(memDC, memBmp);
            DrawMediaPanel(memDC, rc.right, rc.bottom);
            if (g_IsScrolling) SetTimer(hwnd, IDT_ANIMATION, 16, NULL);
            BitBlt(hdc, 0, 0, rc.right, rc.bottom, memDC, 0, 0, SRCCOPY);
            SelectObject(memDC, oldBmp); DeleteObject(memBmp); DeleteDC(memDC);
            EndPaint(hwnd, &ps);
            return 0;
        }

        default:
            if (msg == g_TaskbarCreatedMsg) {
                if (g_TaskbarHook) { UnhookWinEvent(g_TaskbarHook); g_TaskbarHook = nullptr; }
                RegisterTaskbarHook(hwnd);
                return 0;
            }
            break;
    }
    return DefWindowProc(hwnd, msg, wParam, lParam);
}

void MediaThread() {
    winrt::init_apartment();
    GdiplusStartupInput gsi;
    ULONG_PTR gdiToken;
    GdiplusStartup(&gdiToken, &gsi, NULL);

    WNDCLASS wc = { 0 };
    wc.lpfnWndProc   = MediaWndProc;
    wc.hInstance     = GetModuleHandle(NULL);
    wc.lpszClassName = TEXT("WindhawkMusicLounge_GSMTC");
    wc.hCursor       = LoadCursor(NULL, IDC_HAND);
    RegisterClass(&wc);

    HMODULE hUser32 = GetModuleHandle(L"user32.dll");
    auto CreateWindowInBand = hUser32
        ? (pCreateWindowInBand)GetProcAddress(hUser32, "CreateWindowInBand") : nullptr;

    if (CreateWindowInBand) {
        g_hMediaWindow = CreateWindowInBand(
            WS_EX_LAYERED | WS_EX_TOOLWINDOW | WS_EX_TOPMOST,
            wc.lpszClassName, TEXT("MusicLounge"), WS_POPUP | WS_VISIBLE,
            0, 0, g_Settings.width, g_Settings.height,
            NULL, NULL, wc.hInstance, NULL, ZBID_IMMERSIVE_NOTIFICATION);
        if (g_hMediaWindow) Wh_Log(L"Created window in ZBID_IMMERSIVE_NOTIFICATION band");
    }

    if (!g_hMediaWindow) {
        Wh_Log(L"Falling back to CreateWindowEx");
        g_hMediaWindow = CreateWindowEx(
            WS_EX_LAYERED | WS_EX_TOOLWINDOW | WS_EX_TOPMOST,
            wc.lpszClassName, TEXT("MusicLounge"), WS_POPUP | WS_VISIBLE,
            0, 0, g_Settings.width, g_Settings.height,
            NULL, NULL, wc.hInstance, NULL);
    }

    SetLayeredWindowAttributes(g_hMediaWindow, 0, 255, LWA_ALPHA);

    MSG msg;
    while (GetMessage(&msg, NULL, 0, 0)) { TranslateMessage(&msg); DispatchMessage(&msg); }

    UnregisterClass(wc.lpszClassName, wc.hInstance);
    GdiplusShutdown(gdiToken);
    winrt::uninit_apartment();
}

std::thread* g_pMediaThread = nullptr;

BOOL WhTool_ModInit() {
    SetCurrentProcessExplicitAppUserModelID(L"taskbar-music-lounge");
    LoadSettings();
    g_Running = true;
    g_pMediaThread = new std::thread(MediaThread);
    return TRUE;
}

void WhTool_ModUninit() {
    g_Running = false;
    if (g_hMediaWindow) SendMessage(g_hMediaWindow, APP_WM_CLOSE, 0, 0);
    if (g_pMediaThread) {
        if (g_pMediaThread->joinable()) g_pMediaThread->join();
        delete g_pMediaThread;
        g_pMediaThread = nullptr;
    }
}

void WhTool_ModSettingsChanged() {
    LoadSettings();
    if (g_hMediaWindow) {
        SendMessage(g_hMediaWindow, WM_TIMER, IDT_POLL_MEDIA, 0);
        SendMessage(g_hMediaWindow, WM_SETTINGCHANGE, 0, 0);
    }
}

////////////////////////////////////////////////////////////////////////////////
// Windhawk tool mod boilerplate

bool g_isToolModProcessLauncher;
HANDLE g_toolModProcessMutex;

void WINAPI EntryPoint_Hook() { Wh_Log(L">"); ExitThread(0); }

BOOL Wh_ModInit() {
    bool isService = false, isToolModProcess = false, isCurrentToolModProcess = false;
    int argc;
    LPWSTR* argv = CommandLineToArgvW(GetCommandLine(), &argc);
    if (!argv) { Wh_Log(L"CommandLineToArgvW failed"); return FALSE; }

    for (int i = 1; i < argc; i++)
        if (wcscmp(argv[i], L"-service") == 0) { isService = true; break; }

    for (int i = 1; i < argc - 1; i++)
        if (wcscmp(argv[i], L"-tool-mod") == 0) {
            isToolModProcess = true;
            if (wcscmp(argv[i+1], WH_MOD_ID) == 0) isCurrentToolModProcess = true;
            break;
        }

    LocalFree(argv);
    if (isService) return FALSE;

    if (isCurrentToolModProcess) {
        g_toolModProcessMutex = CreateMutex(nullptr, TRUE, L"windhawk-tool-mod_" WH_MOD_ID);
        if (!g_toolModProcessMutex) { Wh_Log(L"CreateMutex failed"); ExitProcess(1); }
        if (GetLastError() == ERROR_ALREADY_EXISTS) { Wh_Log(L"Tool mod already running (%s)", WH_MOD_ID); ExitProcess(1); }
        if (!WhTool_ModInit()) ExitProcess(1);

        auto* dos = (IMAGE_DOS_HEADER*)GetModuleHandle(nullptr);
        auto* nt  = (IMAGE_NT_HEADERS*)((BYTE*)dos + dos->e_lfanew);
        Wh_SetFunctionHook((BYTE*)dos + nt->OptionalHeader.AddressOfEntryPoint, (void*)EntryPoint_Hook, nullptr);
        return TRUE;
    }

    if (isToolModProcess) return FALSE;
    g_isToolModProcessLauncher = true;
    return TRUE;
}

void Wh_ModAfterInit() {
    if (!g_isToolModProcessLauncher) return;

    WCHAR path[MAX_PATH];
    if (!GetModuleFileName(nullptr, path, ARRAYSIZE(path))) { Wh_Log(L"GetModuleFileName failed"); return; }

    WCHAR cmdLine[MAX_PATH + 2 + (sizeof(L" -tool-mod \"" WH_MOD_ID "\"") / sizeof(WCHAR)) - 1];
    swprintf_s(cmdLine, L"\"%s\" -tool-mod \"%s\"", path, WH_MOD_ID);

    HMODULE km = GetModuleHandle(L"kernelbase.dll");
    if (!km) km = GetModuleHandle(L"kernel32.dll");
    if (!km) { Wh_Log(L"No kernelbase.dll/kernel32.dll"); return; }

    using CPIW_t = BOOL(WINAPI*)(HANDLE, LPCWSTR, LPWSTR, LPSECURITY_ATTRIBUTES,
        LPSECURITY_ATTRIBUTES, WINBOOL, DWORD, LPVOID, LPCWSTR, LPSTARTUPINFOW,
        LPPROCESS_INFORMATION, PHANDLE);
    auto pCPIW = (CPIW_t)GetProcAddress(km, "CreateProcessInternalW");
    if (!pCPIW) { Wh_Log(L"No CreateProcessInternalW"); return; }

    STARTUPINFO si{ .cb = sizeof(si), .dwFlags = STARTF_FORCEOFFFEEDBACK };
    PROCESS_INFORMATION pi;
    if (!pCPIW(nullptr, path, cmdLine, nullptr, nullptr, FALSE, NORMAL_PRIORITY_CLASS,
               nullptr, nullptr, &si, &pi, nullptr)) { Wh_Log(L"CreateProcess failed"); return; }
    CloseHandle(pi.hProcess);
    CloseHandle(pi.hThread);
}

void Wh_ModSettingsChanged() {
    if (g_isToolModProcessLauncher) return;
    WhTool_ModSettingsChanged();
}

void Wh_ModUninit() {
    if (g_isToolModProcessLauncher) return;
    WhTool_ModUninit();
    ExitProcess(0);
}
