/*
- PanelWidth: 300
  $name: Panel Width
  $description: Width of the music panel in pixels
- PanelHeight: 48
  $name: Panel Height
  $description: Height of the music panel in pixels (minimum 24)
- FontSize: 11
  $name: Font Size
